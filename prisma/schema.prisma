// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model airportNames {
  id    Int     @id @default(autoincrement())
  code  String  @unique
  name  String
}

model airlineNames {
  id    Int     @id @default(autoincrement())
  code  String  @unique
  name  String
}

model flights {
  @@id([uniqueId, scanned_airport])
  uniqueId         String
  scanned_airport String  // The airport we are looking at (e.g. "BGO")
  
  flightId        String
  airline         String?
  direction       String  // "A" or "D"
  dom_int         String
  
  // The "Other" end of the route relative to this airport
  // If scanned_airport is BGO (Dep), this is the Destination.
  // If scanned_airport is OSL (Arr), this is the Origin.
  related_airport String 
  
  // Generic fields (Context depends on direction)
  schedule_time   DateTime
  gate            String?
  gate_status_code String?
  gate_status_desc String?

  // Flight status
  status_code     String?
  status_desc     String?
  status_time     DateTime?
  
  // Specifics
  aircraft_type    String?
  check_in        String? // Only populated if direction=D
  belt            String? // Only populated if direction=A
  belt_status_code  String?
  belt_status_desc  String?
  via             String[] // Postgres Array

  lastSyncSource   String?
  updatedAt       DateTime @updatedAt
}

model avinorAirports {
  id      Int     @id @default(autoincrement())
  code    String  @unique
  name    String
  altName String
}